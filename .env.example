PORT=3000
NODE_ENV=development

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (outbound claim emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Q-Dispatch <your@gmail.com>

# Insurer email addresses
INSURER_EMAIL_STAR=claims@starhealth.in
INSURER_EMAIL_CARE=claims@carehealth.in
INSURER_EMAIL_HDFC=claims@hdfcergo.com
INSURER_EMAIL_NIA=claims@newindia.co.in

# IMAP (inbound reply monitoring)
IMAP_HOST=imap.gmail.com
IMAP_USER=your@gmail.com
IMAP_PASS=your_app_password

# App login
LOGIN_USER=qdispatch_admin
LOGIN_PASS=ChangeThisPassword123
SESSION_SECRET=replace_with_64_char_random_string

# Business
QAI_FEE_RATE=0.005
DB_PATH=./data/qdispatch.db

# Demo seed: set to "full" to load the complete demo roster on first boot
SEED_DEMO=

# Dispatch channel: "email" (default) or "nhcx" (requires ABDM onboarding)
DISPATCH_CHANNEL=email
# NHCX / ABDM gateway endpoint + key (set once onboarded; enables NHCX dispatch)
NHCX_ENDPOINT=
NHCX_API_KEY=
